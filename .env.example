# ============================================================
#  AI Git Guard — Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to source control.
# ============================================================
  
# --- GitHub ---
GITHUB_TOKEN=
GITHUB_ENTERPRISE_URL=
GITHUB_ORG=IN-Information-Security
  
# --- LLM Provider ---
# Options: ollama | claude | openai | copilot
LLM_PROVIDER=github_models
  
# Ollama (local, zero-cost)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
  
# Cloud providers (only needed if LLM_PROVIDER is set to these)
ANTHROPIC_BASE_URL=https://openrouter.ai/api
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=openrouter/free
OPENAI_API_KEY=
COPILOT_TOKEN=

# GitHub Models (GitHub Marketplace — uses GITHUB_TOKEN for auth)
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com
GITHUB_MODELS_MODEL=gpt-5
  
# --- Cache ---
CACHE_TTL_MINUTES=30
  
# --- Output ---
OUTPUT_DIR=./reports
DEFAULT_OUTPUT_FORMAT=text
  
# --- Logging ---
LOG_LEVEL=INFO
